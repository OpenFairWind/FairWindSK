    "dataWidgets": [
        {
            "id": "position",
            "name": "Position",
            "icon": ":/resources/svg/OpenBridge/lcd-position.svg",
            "type": "position",
            "signalKPath": "navigation.position",
            "sourceUnit": "",
            "defaultUnit": "",
            "updatePolicy": "instant",
            "period": 1000,
            "minPeriod": 200,
            "defaultTopEnabled": true,
            "defaultBottomEnabled": false,
            "expandHorizontally": true,
            "expandVertically": false
        },
        {
            "id": "position_rows",
            "name": "Position Rows",
            "icon": ":/resources/svg/OpenBridge/lcd-position.svg",
